<%= form_with model: post, url: (post.new_record? ? posts_path : post_path(post.slug)), local: true, multipart: true, class: "overleaf-ide-container" do |f| %>
  
  <% if post.errors.any? %>
    <div class="form-errors-banner">
      <p><strong><%= pluralize(post.errors.count, "error") %> impidieron guardar:</strong></p>
      <ul><% post.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="ide-workspace">
    <aside class="overleaf-sidebar">
      <div class="sidebar-section-title">ESTRUCTURA & METADATOS</div>
      
      <div class="sidebar-field">
        <%= f.label :title, "Título" %>
        <%= f.text_field :title, required: true, placeholder: "main.tex" %>
      </div>

      <div class="sidebar-field">
        <%= f.label :path, "Ruta (Estructura)" %>
        <%= f.text_field :path, id: "post_path_input", list: "paths-existentes", required: true, placeholder: "Programacion/Ruby/Rails" %>
        <datalist id="paths-existentes">
          <% Post.distinct.pluck(:path).compact.sort.each do |p| %>
            <option value="<%= p %>">
          <% end %>
        </datalist>
      </div>

      <div class="sidebar-field">
        <%= f.label :description, "Descripción Corta" %>
        <%= f.text_area :description, rows: 4, placeholder: "Extracto para tarjetas..." %>
      </div>

      <div class="sidebar-field">
        <%= f.label :image, "Imagen de Portada" %>
        <%= f.file_field :image, accept: "image/*" %>
        <% if post.image.attached? %>
          <div class="sidebar-thumb-preview">
            <%= image_tag post.image %>
          </div>
        <% end %>
      </div>

      <div class="sidebar-field checkbox-field">
        <%= f.check_box :published %>
        <%= f.label :published, "Publicada / Visible" %>
      </div>
    </aside>

    <main class="overleaf-editor-zone">
      <div class="editor-top-toolbar">
        <div class="toolbar-left">
          <span class="file-tab active">body.md</span>
        </div>
        <div class="toolbar-right">
          <span class="hint-text">Imágenes: ![[img.png]] o ![[/Ruta/Absoluta/img.png]]</span>
        </div>
      </div>
      
      <div class="editor-textarea-wrapper">
        <%= f.text_area :body, placeholder: "## Próximos pasos sugeridos\n\n* Añadir partículas...\n\nEscribe aquí tu Markdown.", class: "ide-textarea" %>
      </div>
    </main>
  </div>

  <footer class="overleaf-bottom-tray">
    <div class="tray-gallery-section" style="display: flex; flex-direction: column; justify-content: center;">
      <div class="tray-header" style="margin-bottom: 5px; border-bottom: none; display: flex; align-items: center; gap: 15px;">
        <span style="font-size: 0.9rem; color: var(--text-muted);">
          <i class="fa-solid fa-folder-tree"></i> Repositorio de Medios
        </span>
        <%= link_to "📂 Abrir Carpeta de esta Ruta", media_assets_path(path: post.path.presence || "General"), id: "media_manager_link", target: "_blank", class: "btn-ide-secondary", style: "text-decoration: none;" %>
      </div>
      <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">
        Sube las imágenes en el gestor y usa <code>![[nombre.png]]</code> en el editor.
      </p>
    </div>

    <div class="ide-actions-bar">
      <%= link_to "Cancelar", posts_path, class: "btn-ide-secondary" %>
      <%= f.submit (post.new_record? ? "Compilar & Publicar" : "Recompilar (Guardar)"), class: "btn-ide-primary" %>
    </div>
  </footer>
<% end %>

<script>
  document.addEventListener("turbo:load", () => {
    const pathInput = document.getElementById("post_path_input");
    const mediaLink = document.getElementById("media_manager_link");

    if (pathInput && mediaLink) {
      pathInput.addEventListener("input", (e) => {
        const currentPath = e.target.value.trim() || "General";
        mediaLink.href = `/media_assets?path=${encodeURIComponent(currentPath)}`;
      });
    }
  });
</script>