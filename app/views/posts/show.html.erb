<% content_for :title, @post.title %>

<section class="single-page">
  <div class="single-header">
    <span class="date"><%= @post.published_at&.strftime("%d de %B, %Y") %></span>
    <% if @post.tag.present? %><span class="tag"><%= @post.tag %></span><% end %>
    <h1><%= @post.title %></h1>
    <% if @post.description.present? %><p class="single-desc"><%= @post.description %></p><% end %>
  </div>

  <% if @post.image.attached? %>
    <div class="single-image">
      <%= image_tag @post.image, alt: @post.title %>
    </div>
  <% end %>

  <div class="markdown-body">
    <%= markdown(@post.body) %>
  </div>

  <% if logged_in? %>
    <div class="admin-actions single-admin-actions">
      <%= link_to "Editar entrada", edit_post_path(@post.slug), class: "btn-sm" %>
      <%= button_to "Eliminar", post_path(@post.slug), method: :delete, class: "btn-tiny btn-tiny-danger",
                    form: { data: { turbo_confirm: "¿Eliminar esta entrada?" } } %>
    </div>
  <% end %>

  <p><%= link_to "← Volver al blog", posts_path, class: "link-more" %></p>
</section>
