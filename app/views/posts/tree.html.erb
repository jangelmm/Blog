<section class="posts-tree-section" style="max-width: var(--max-width); margin: 0 auto; padding: 3rem 1.8rem;">
  <div class="section-header">
    <h2>
      <i class="fa-solid fa-folder-open" style="color: var(--accent); margin-right: 0.5rem;"></i>
      Índice de: <span style="font-family: 'JetBrains Mono', monospace; color: var(--text-secondary);"><%= params[:path] %>/</span>
    </h2>
    <%= link_to "Volver al blog", posts_path, class: "link-more" %>
  </div>

  <div class="tree-explorer-container" style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow-card);">
    <% if @tree.empty? %>
      <p class="empty-state">Esta sección no contiene entradas ni subcarpetas todavía.</p>
    <% else %>
      <ul class="tree-root-list" style="list-style: none; padding: 0; margin: 0;">
        
        <% @tree.each do |name, node| %>
          <% next if name == :_posts %>
          
          <li style="margin-bottom: 1rem;">
            <details class="tree-folder-node">
              <summary class="folder-header" style="display: flex; align-items: center; gap: 0.6rem; color: var(--text-primary); font-weight: 600; cursor: pointer; user-select: none; padding: 0.4rem 0;">
                <i class="fa-solid fa-folder" style="color: var(--accent);"></i>
                <span style="transition: color var(--transition);" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-primary)'">
                  <%= name.capitalize %>
                </span>
              </summary>
              
              <% if node.is_a?(Hash) && node[:_posts].present? %>
                <ul class="tree-posts-list" style="list-style: none; padding-left: 1.8rem; margin-top: 0.5rem; border-left: 2px solid var(--border-light); margin-left: 0.4rem;">
                  <% node[:_posts].each do |post| %>
                    <li style="margin-bottom: 0.6rem; display: flex; align-items: center; gap: 0.6rem;">
                      <i class="fa-solid fa-file-code" style="color: var(--text-muted); font-size: 0.85rem;"></i>
                      <%= link_to post.title, post_show_path(path: post.path, slug: post.slug), 
                                  style: "color: var(--accent); text-decoration: none; font-size: 0.95rem; transition: all var(--transition);", 
                                  onmouseover: "this.style.filter='brightness(1.2)'",
                                  onmouseout: "this.style.filter='none'" %>
                      
                      <% unless post.published? %>
                        <span class="draft-badge" style="font-size: 0.7rem; background: rgba(248, 113, 113, 0.1); color: var(--danger); padding: 0.15rem 0.5rem; border-radius: 50px; text-transform: uppercase; letter-spacing: 0.5px;">Borrador</span>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </details>
          </li>
        <% end %>

        <% if @tree[:_posts].present? %>
          <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border-light);">
            <% @tree[:_posts].each do |post| %>
              <li style="margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.6rem;">
                <i class="fa-solid fa-file-lines" style="color: var(--accent-2); font-size: 0.9rem;"></i>
                <%= link_to post.title, post_show_path(path: post.path, slug: post.slug), 
                            style: "color: var(--text-primary); text-decoration: none; font-weight: 500; transition: color var(--transition);", 
                            onmouseover: "this.style.color='var(--accent-2)'",
                            onmouseout: "this.style.color='var(--text-primary)'" %>
              </li>
            <% end %>
          </div>
        <% end %>

      </ul>
    <% end %>
  </div>
  
  <style>
    details > summary { list-style: none; }
    details > summary::-webkit-details-marker { display: none; }
  </style>
</section>