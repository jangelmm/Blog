<% content_for :title, @project.title %>

<section class="single-page">
  <div class="single-header">
    <h1><%= @project.title %></h1>
    <% if @project.description.present? %><p class="single-desc"><%= @project.description %></p><% end %>
    <div class="project-tech" style="justify-content:center; margin-top:1rem;">
      <% @project.tech_list.each do |t| %><span><%= t %></span><% end %>
    </div>
  </div>

  <div class="single-image">
    <% if @project.image.attached? %>
      <%= image_tag @project.image, alt: @project.title %>
    <% else %>
      <div class="project-img" style="aspect-ratio:16/9; border-radius: var(--radius);">
        <i class="<%= @project.icon.presence || 'fa-solid fa-cube' %>" style="font-size:4rem; color:var(--accent);"></i>
      </div>
    <% end %>
  </div>

  <div class="markdown-body">
    <article class="post-content" data-controller="math">
      <%= markdown(@project.body) %>
    </article>
  </div>

  <div class="post-citation-card" id="citation-block">
    <div class="citation-content">
      <div class="citation-header">
        <h3 class="citation-title"><%= @project.title %></h3>
        <button class="btn-copy-citation" id="copyCitationBtn" title="Copiar cita en formato APA">
          <i class="fa-regular fa-copy"></i> Copiar
        </button>
      </div>
      
      <div class="citation-url">
        <%= link_to request.original_url, request.original_url, class: "url-link" %>
      </div>
      
      <div class="citation-metadata">
        <div class="meta-group">
          <span class="meta-label">Autor</span>
          <span class="meta-value"><%= Profile.first&.name || "Jesús Ángel Martínez Mendoza" %></span>
        </div>
        <div class="meta-group">
          <span class="meta-label">Publicado</span>
          <span class="meta-value"><%= @project.created_at.strftime("%Y-%m-%d") %></span>
        </div>
        <div class="meta-group">
          <span class="meta-label">Licencia</span>
          <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer" class="meta-value license-link">
            CC BY-NC-SA 4.0
          </a>
        </div>
      </div>
    </div>
    
    <i class="fa-brands fa-creative-commons bg-cc-icon"></i>
  </div>

  <script>
    document.getElementById('copyCitationBtn').addEventListener('click', function() {
      const author = "<%= Profile.first&.name || 'Martínez Mendoza, J. Á.' %>";
      const date = "<%= @project.created_at.strftime('%Y, %d de %B') %>";
      const title = "<%= @project.title %>";
      const url = "<%= request.original_url %>";
      
      const citationText = `${author}. (${date}). ${title}. Recuperado de ${url}`;
      
      navigator.clipboard.writeText(citationText).then(() => {
        const btn = this;
        const originalText = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check"></i> ¡Copiado!';
        btn.style.color = "var(--accent-2)"; 
        btn.style.borderColor = "var(--accent-2)";
        
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.style.color = "";
          btn.style.borderColor = "";
        }, 2000);
      });
    });
  </script>
  <% if logged_in? %>
    <div class="admin-actions single-admin-actions">
      <%= link_to "Editar proyecto", edit_project_path(@project.slug), class: "btn-sm" %>
      <%= button_to "Eliminar", project_path(@project.slug), method: :delete, class: "btn-tiny btn-tiny-danger",
                    form: { data: { turbo_confirm: "¿Eliminar este proyecto?" } } %>
    </div>
  <% end %>

  <p><%= link_to "← Volver a proyectos", projects_path, class: "link-more" %></p>
</section>