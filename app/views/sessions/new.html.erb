<section class="form-page" style="max-width:420px;">
  <div class="section-header"><h2><i class="fa-solid fa-lock"></i> Acceso privado</h2></div>

  <%= form_with url: login_path, method: :post, local: true, class: "admin-form" do |f| %>
    <div class="field">
      <%= label_tag :email, "Correo" %>
      <%= email_field_tag :email, params[:email], required: true %>
    </div>
    <div class="field">
      <%= label_tag :password, "Contraseña" %>
      <%= password_field_tag :password, nil, required: true %>
    </div>
    <div class="form-actions">
      <%= submit_tag "Entrar", class: "btn-primary" %>
    </div>
  <% end %>
</section>
